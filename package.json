{
  "name": "tazhan-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "TAZHAN desktop client for Codex",
  "author": "aojianhua",
  "main": "dist/main/index.js",
  "build": {
    "appId": "com.tazhan.desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "!dist/**/*.map"
    ],
    "npmRebuild": false,
    "win": {
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "scripts": {
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main": "tsup --config tsup.config.ts --watch",
    "dev:electron": "wait-on tcp:5173 dist/main/index.js dist/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:legacy": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:main\" \"pnpm dev:electron\"",
    "dev": "node scripts/dev.mjs",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsup --config tsup.config.ts",
    "build": "pnpm build:main && pnpm build:renderer",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "release:win": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ssh2": "^1.11.18",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  }
}
